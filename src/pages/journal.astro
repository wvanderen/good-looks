---
import UswdsLayout from "../layouts/UswdsLayout.astro";
---

<UswdsLayout
  title="Journal | Good Looks"
  description="Start and review ride journal entries in Good Looks."
>
  <section class="usa-section app-intro">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-8">
          <p class="usa-intro">Ride journal</p>
          <h1>Capture a ride entry.</h1>
          <p>
            Record the basics of a ride, including location notes and conditions
            that can later be paired with public weather data.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="usa-section usa-section--light" aria-labelledby="journal-form-heading">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-8 desktop:grid-col-6">
          <h2 id="journal-form-heading" tabindex="-1">Ride details</h2>
          <form
            class="usa-form usa-form--large"
            action="/rides/"
            method="get"
            novalidate
            data-journal-form
            data-entry-step="form"
          >
            <p class="usa-hint">
              Required fields are marked with <abbr title="required">*</abbr>.
            </p>
            <div
              class="usa-alert usa-alert--error app-validation-summary"
              id="journal-validation-summary"
              role="alert"
              tabindex="-1"
              hidden
            >
              <div class="usa-alert__body">
                <h2 class="usa-alert__heading" id="journal-validation-heading">
                  Correct the highlighted fields.
                </h2>
                <ul class="usa-list" id="journal-validation-list"></ul>
              </div>
            </div>

            <fieldset class="usa-fieldset">
              <legend class="usa-legend usa-legend--large">When and where</legend>

              <label class="usa-label" for="ride-date">
                Ride date <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input"
                id="ride-date"
                name="ride-date"
                type="date"
                required
              />

              <label class="usa-label" for="street-address">
                Starting street address <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input"
                id="street-address"
                name="street-address"
                type="text"
                autocomplete="street-address"
                required
              />

              <label class="usa-label" for="address-city">
                City <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input"
                id="address-city"
                name="address-city"
                type="text"
                autocomplete="address-level2"
                required
              />

              <label class="usa-label" for="address-state">
                State <abbr title="required">*</abbr>
              </label>
              <select
                class="usa-select"
                id="address-state"
                name="address-state"
                autocomplete="address-level1"
                required
              >
                <option value="">- Select -</option>
                <option value="AL">Alabama</option>
                <option value="AK">Alaska</option>
                <option value="AZ">Arizona</option>
                <option value="AR">Arkansas</option>
                <option value="CA">California</option>
                <option value="CO">Colorado</option>
                <option value="CT">Connecticut</option>
                <option value="DE">Delaware</option>
                <option value="DC">District of Columbia</option>
                <option value="FL">Florida</option>
                <option value="GA">Georgia</option>
                <option value="HI">Hawaii</option>
                <option value="ID">Idaho</option>
                <option value="IL">Illinois</option>
                <option value="IN">Indiana</option>
                <option value="IA">Iowa</option>
                <option value="KS">Kansas</option>
                <option value="KY">Kentucky</option>
                <option value="LA">Louisiana</option>
                <option value="ME">Maine</option>
                <option value="MD">Maryland</option>
                <option value="MA">Massachusetts</option>
                <option value="MI">Michigan</option>
                <option value="MN">Minnesota</option>
                <option value="MS">Mississippi</option>
                <option value="MO">Missouri</option>
                <option value="MT">Montana</option>
                <option value="NE">Nebraska</option>
                <option value="NV">Nevada</option>
                <option value="NH">New Hampshire</option>
                <option value="NJ">New Jersey</option>
                <option value="NM">New Mexico</option>
                <option value="NY">New York</option>
                <option value="NC">North Carolina</option>
                <option value="ND">North Dakota</option>
                <option value="OH">Ohio</option>
                <option value="OK">Oklahoma</option>
                <option value="OR">Oregon</option>
                <option value="PA">Pennsylvania</option>
                <option value="RI">Rhode Island</option>
                <option value="SC">South Carolina</option>
                <option value="SD">South Dakota</option>
                <option value="TN">Tennessee</option>
                <option value="TX">Texas</option>
                <option value="UT">Utah</option>
                <option value="VT">Vermont</option>
                <option value="VA">Virginia</option>
                <option value="WA">Washington</option>
                <option value="WV">West Virginia</option>
                <option value="WI">Wisconsin</option>
                <option value="WY">Wyoming</option>
              </select>

              <label class="usa-label" for="address-zip">
                ZIP code <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input usa-input--medium"
                id="address-zip"
                name="address-zip"
                type="text"
                inputmode="numeric"
                autocomplete="postal-code"
                pattern="[0-9]{5}(-[0-9]{4})?"
                required
              />

              <input
                id="address-label"
                name="address-label"
                type="hidden"
                data-address-label
              />
              <input
                id="address-latitude"
                name="address-latitude"
                type="hidden"
                data-address-latitude
              />
              <input
                id="address-longitude"
                name="address-longitude"
                type="hidden"
                data-address-longitude
              />
              <input
                id="weather-summary"
                name="weather-summary"
                type="hidden"
                data-weather-summary
              />
              <input
                id="weather-temperature"
                name="weather-temperature"
                type="hidden"
                data-weather-temperature
              />
              <input
                id="weather-wind"
                name="weather-wind"
                type="hidden"
                data-weather-wind
              />
              <input
                id="weather-precipitation"
                name="weather-precipitation"
                type="hidden"
                data-weather-precipitation
              />
              <input
                id="weather-source"
                name="weather-source"
                type="hidden"
                data-weather-source
              />
              <input
                id="weather-condition"
                name="weather-condition"
                type="hidden"
                data-weather-condition
              />

              <div
                class="usa-alert usa-alert--info usa-alert--slim margin-top-3"
                data-address-lookup-status
                role="status"
                aria-live="polite"
                hidden
              >
                <div class="usa-alert__body">
                  <p class="usa-alert__text" data-address-lookup-message></p>
                </div>
              </div>
              <div
                class="usa-alert usa-alert--info usa-alert--slim margin-top-2"
                data-weather-lookup-status
                role="status"
                aria-live="polite"
                hidden
              >
                <div class="usa-alert__body">
                  <p class="usa-alert__text" data-weather-lookup-message></p>
                </div>
              </div>

              <section
                class="app-conditions-panel margin-top-3"
                aria-labelledby="conditions-panel-heading"
                data-conditions-panel
              >
                <div class="app-conditions-panel__header">
                  <h3 id="conditions-panel-heading" class="margin-y-0">
                    Ride conditions
                  </h3>
                  <span
                    class="usa-tag app-conditions-panel__tag"
                    data-weather-condition-label
                    hidden
                  ></span>
                </div>
                <div
                  class="usa-alert usa-alert--info usa-alert--slim margin-top-2"
                  data-weather-empty-state
                >
                  <div class="usa-alert__body">
                    <p class="usa-alert__text" data-weather-empty-message>
                      Complete the starting address to load public weather data.
                    </p>
                  </div>
                </div>
                <div
                  class="usa-alert usa-alert--error margin-top-2"
                  data-weather-error-state
                  role="alert"
                  hidden
                >
                  <div class="usa-alert__body">
                    <h4 class="usa-alert__heading">Weather could not load</h4>
                    <p class="usa-alert__text" data-weather-error-message>
                      Try again in a moment or continue without a forecast.
                    </p>
                  </div>
                </div>
                <dl
                  class="app-conditions-grid"
                  data-weather-summary-panel
                  hidden
                >
                  <div>
                    <dt>Temperature</dt>
                    <dd data-weather-panel-temperature>Unavailable</dd>
                  </div>
                  <div>
                    <dt>Wind</dt>
                    <dd data-weather-panel-wind>Unavailable</dd>
                  </div>
                  <div>
                    <dt>Forecast</dt>
                    <dd data-weather-panel-summary>Unavailable</dd>
                  </div>
                  <div>
                    <dt>Source</dt>
                    <dd data-weather-panel-source>Unavailable</dd>
                  </div>
                </dl>
              </section>
            </fieldset>

            <fieldset class="usa-fieldset margin-top-4">
              <legend class="usa-legend usa-legend--large">Ride activity</legend>

              <label class="usa-label" for="ride-distance">
                Distance in miles <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input usa-input--small"
                id="ride-distance"
                name="ride-distance"
                type="number"
                inputmode="decimal"
                min="0"
                step="0.1"
                required
              />

              <label class="usa-label" for="ride-duration">
                Duration in minutes <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input usa-input--small"
                id="ride-duration"
                name="ride-duration"
                type="number"
                inputmode="numeric"
                min="1"
                step="1"
                required
              />
            </fieldset>

            <fieldset class="usa-fieldset app-effort-fieldset margin-top-4">
              <legend class="usa-legend usa-legend--large">
                Effort <abbr title="required">*</abbr>
              </legend>
              <div class="app-effort-options">
                <div class="usa-radio">
                  <input
                    class="usa-radio__input"
                    id="effort-easy"
                    name="effort"
                    type="radio"
                    value="easy"
                    required
                  />
                  <label class="usa-radio__label" for="effort-easy">Easy</label>
                </div>
                <div class="usa-radio">
                  <input
                    class="usa-radio__input"
                    id="effort-moderate"
                    name="effort"
                    type="radio"
                    value="moderate"
                  />
                  <label class="usa-radio__label" for="effort-moderate">Moderate</label>
                </div>
                <div class="usa-radio">
                  <input
                    class="usa-radio__input"
                    id="effort-hard"
                    name="effort"
                    type="radio"
                    value="hard"
                  />
                  <label class="usa-radio__label" for="effort-hard">Hard</label>
                </div>
              </div>
            </fieldset>

            <fieldset class="usa-fieldset margin-top-4">
              <legend class="usa-legend usa-legend--large">Notes</legend>

              <label class="usa-label" for="weather-notes">Weather notes</label>
              <div class="usa-hint" id="weather-notes-hint">
                Add wind, temperature, visibility, or road condition details.
              </div>
              <textarea
                class="usa-textarea"
                id="weather-notes"
                name="weather-notes"
                aria-describedby="weather-notes-hint"
              ></textarea>

              <label class="usa-label" for="ride-notes">Ride notes</label>
              <div class="usa-hint" id="ride-notes-hint">
                Add route highlights, stops, comfort notes, or anything to remember.
              </div>
              <textarea
                class="usa-textarea"
                id="ride-notes"
                name="ride-notes"
                aria-describedby="ride-notes-hint"
              ></textarea>
            </fieldset>

            <button class="usa-button margin-top-4" type="submit" data-continue-ride>
              Continue
            </button>
          </form>

          <section
            class="margin-top-5"
            aria-labelledby="journal-review-heading"
            data-journal-review
            hidden
          >
            <h2 id="journal-review-heading" tabindex="-1">Review ride details</h2>
            <p>
              Confirm these normalized details before saving the ride entry.
            </p>
            <dl class="app-review-list" data-review-list></dl>
            <div
              class="usa-alert margin-top-4"
              data-save-status
              tabindex="-1"
              hidden
            >
              <div class="usa-alert__body">
                <h3 class="usa-alert__heading" data-save-status-heading></h3>
                <p class="usa-alert__text" data-save-status-message></p>
              </div>
            </div>
            <div class="margin-top-4">
              <button class="usa-button" type="button" data-save-ride>
                Save ride entry
              </button>
              <button
                class="usa-button usa-button--outline"
                type="button"
                data-edit-ride
              >
                Edit details
              </button>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { amplifyClient } from "../lib/amplifyClient";

    const journalForm = document.querySelector("[data-journal-form]");
    const journalReview = document.querySelector("[data-journal-review]");
    const reviewHeading = document.querySelector("#journal-review-heading");
    const reviewList = document.querySelector("[data-review-list]");
    const editRideButton = document.querySelector("[data-edit-ride]");
    const saveRideButton = document.querySelector("[data-save-ride]");
    const saveStatus = document.querySelector("[data-save-status]");
    const saveStatusHeading = document.querySelector("[data-save-status-heading]");
    const saveStatusMessage = document.querySelector("[data-save-status-message]");

    if (journalForm instanceof HTMLFormElement) {
      const validationSummary = journalForm.querySelector(
        "#journal-validation-summary",
      );
      const validationList = journalForm.querySelector("#journal-validation-list");
      const addressLookupStatus = journalForm.querySelector(
        "[data-address-lookup-status]",
      );
      const addressLookupMessage = journalForm.querySelector(
        "[data-address-lookup-message]",
      );
      const weatherLookupStatus = journalForm.querySelector(
        "[data-weather-lookup-status]",
      );
      const weatherLookupMessage = journalForm.querySelector(
        "[data-weather-lookup-message]",
      );
      const continueRideButton = journalForm.querySelector("[data-continue-ride]");
      const addressLabelInput = journalForm.querySelector("[data-address-label]");
      const addressLatitudeInput = journalForm.querySelector(
        "[data-address-latitude]",
      );
      const addressLongitudeInput = journalForm.querySelector(
        "[data-address-longitude]",
      );
      const weatherSummaryInput = journalForm.querySelector(
        "[data-weather-summary]",
      );
      const weatherTemperatureInput = journalForm.querySelector(
        "[data-weather-temperature]",
      );
      const weatherWindInput = journalForm.querySelector("[data-weather-wind]");
      const weatherPrecipitationInput = journalForm.querySelector(
        "[data-weather-precipitation]",
      );
      const weatherSourceInput = journalForm.querySelector("[data-weather-source]");
      const weatherConditionInput = journalForm.querySelector(
        "[data-weather-condition]",
      );
      const weatherEmptyState = journalForm.querySelector(
        "[data-weather-empty-state]",
      );
      const weatherEmptyMessage = journalForm.querySelector(
        "[data-weather-empty-message]",
      );
      const weatherErrorState = journalForm.querySelector(
        "[data-weather-error-state]",
      );
      const weatherErrorMessage = journalForm.querySelector(
        "[data-weather-error-message]",
      );
      const weatherSummaryPanel = journalForm.querySelector(
        "[data-weather-summary-panel]",
      );
      const weatherConditionLabel = journalForm.querySelector(
        "[data-weather-condition-label]",
      );
      const weatherPanelTemperature = journalForm.querySelector(
        "[data-weather-panel-temperature]",
      );
      const weatherPanelWind = journalForm.querySelector("[data-weather-panel-wind]");
      const weatherPanelSummary = journalForm.querySelector(
        "[data-weather-panel-summary]",
      );
      const weatherPanelSource = journalForm.querySelector(
        "[data-weather-panel-source]",
      );
      const formControls = Array.from(
        journalForm.querySelectorAll("input, select, textarea"),
      ).filter(
        (control) =>
          control instanceof HTMLInputElement ||
          control instanceof HTMLSelectElement ||
          control instanceof HTMLTextAreaElement,
      );

      const fieldLabels = new Map([
        ["ride-date", "Ride date"],
        ["street-address", "Starting street address"],
        ["address-city", "City"],
        ["address-state", "State"],
        ["address-zip", "ZIP code"],
        ["ride-distance", "Distance in miles"],
        ["ride-duration", "Duration in minutes"],
        ["effort", "Effort"],
      ]);

      const requiredMessages = new Map([
        ["address-state", "Select the state where the ride started."],
        ["effort", "Select how hard the ride felt."],
      ]);

      const invalidMessages = new Map([
        ["address-zip", "Enter a 5-digit ZIP code, or ZIP+4."],
        ["ride-distance", "Enter a distance of 0 miles or more, using tenths of a mile if needed."],
        ["ride-duration", "Enter a whole number of minutes greater than 0."],
      ]);

      const effortLabels = new Map([
        ["easy", "Easy"],
        ["moderate", "Moderate"],
        ["hard", "Hard"],
      ]);

      const addressFieldNames = new Set([
        "street-address",
        "address-city",
        "address-state",
        "address-zip",
      ]);
      const addressLookupFieldNames = [
        "street-address",
        "address-city",
        "address-state",
        "address-zip",
      ];
      let addressLookupTimer = 0;
      let lastRequestedAddress = "";

      const originalDescriptions = new Map(
        formControls.map((control) => [
          control.id,
          control.getAttribute("aria-describedby") || "",
        ]),
      );

      const getFieldKey = (control) =>
        control.name === "effort" ? "effort" : control.id;

      const getFieldLabel = (control) => {
        const fieldKey = getFieldKey(control);
        return (
          fieldLabels.get(fieldKey) ||
          control.labels?.[0]?.textContent?.replace("*", "").trim() ||
          "This field"
        );
      };

      const getErrorMessage = (control) => {
        const fieldKey = getFieldKey(control);

        if (control.validity.valueMissing) {
          return (
            requiredMessages.get(fieldKey) ||
            `Enter ${getFieldLabel(control).toLowerCase()}.`
          );
        }

        if (
          control.validity.rangeUnderflow ||
          control.validity.stepMismatch ||
          control.validity.badInput ||
          control.validity.patternMismatch
        ) {
          return (
            invalidMessages.get(fieldKey) ||
            `Enter a valid ${getFieldLabel(control).toLowerCase()}.`
          );
        }

        return (
          control.validationMessage ||
          `Enter a valid ${getFieldLabel(control).toLowerCase()}.`
        );
      };

      const getFormGroup = (control) => {
        if (control.name === "effort") {
          return control.closest("fieldset");
        }

        return control.closest(".usa-form-group") || control.parentElement;
      };

      const getInvalidControls = () => {
        const invalidControls = [];
        const seenFields = new Set();

        for (const control of formControls) {
          const fieldKey = getFieldKey(control);

          if (seenFields.has(fieldKey) || control.validity.valid) {
            continue;
          }

          seenFields.add(fieldKey);
          invalidControls.push(control);
        }

        return invalidControls;
      };

      const getControl = (name) => journalForm.elements.namedItem(name);

      const getTextValue = (name) => {
        const control = getControl(name);

        if (
          control instanceof HTMLInputElement ||
          control instanceof HTMLSelectElement ||
          control instanceof HTMLTextAreaElement
        ) {
          return control.value.trim();
        }

        return "";
      };

      const setHiddenValue = (control, value) => {
        if (control instanceof HTMLInputElement) {
          control.value = value;
        }
      };

      const setAddressLookupStatus = (variant, message) => {
        if (!addressLookupStatus || !addressLookupMessage) {
          return;
        }

        addressLookupStatus.classList.remove(
          "usa-alert--error",
          "usa-alert--info",
          "usa-alert--success",
        );
        addressLookupStatus.classList.add(`usa-alert--${variant}`);
        addressLookupMessage.textContent = message;
        addressLookupStatus.removeAttribute("hidden");
      };

      const setWeatherLookupStatus = (variant, message) => {
        if (!weatherLookupStatus || !weatherLookupMessage) {
          return;
        }

        weatherLookupStatus.classList.remove(
          "usa-alert--error",
          "usa-alert--info",
          "usa-alert--success",
          "usa-alert--warning",
        );
        weatherLookupStatus.classList.add(`usa-alert--${variant}`);
        weatherLookupMessage.textContent = message;
        weatherLookupStatus.removeAttribute("hidden");
      };

      const clearAddressLookupStatus = () => {
        addressLookupStatus?.setAttribute("hidden", "");
        if (addressLookupMessage) {
          addressLookupMessage.textContent = "";
        }
      };

      const clearWeatherLookupStatus = () => {
        weatherLookupStatus?.setAttribute("hidden", "");
        if (weatherLookupMessage) {
          weatherLookupMessage.textContent = "";
        }
      };

      const conditionLabels = new Map([
        ["favorable", "Favorable"],
        ["watch_wind", "Watch wind"],
        ["wet", "Wet roads"],
        ["hot", "Hot ride"],
        ["cold", "Cold ride"],
        ["unknown", "Unknown"],
      ]);

      const setWeatherPanelEmpty = (
        message = "Complete the starting address to load public weather data.",
      ) => {
        weatherEmptyState?.removeAttribute("hidden");
        weatherErrorState?.setAttribute("hidden", "");
        weatherSummaryPanel?.setAttribute("hidden", "");
        weatherConditionLabel?.setAttribute("hidden", "");

        if (weatherEmptyMessage) {
          weatherEmptyMessage.textContent = message;
        }
      };

      const setWeatherPanelError = (message) => {
        weatherEmptyState?.setAttribute("hidden", "");
        weatherErrorState?.removeAttribute("hidden");
        weatherSummaryPanel?.setAttribute("hidden", "");
        weatherConditionLabel?.setAttribute("hidden", "");

        if (weatherErrorMessage) {
          weatherErrorMessage.textContent = message;
        }
      };

      const setWeatherPanelSummary = ({
        temperature,
        wind,
        summary,
        source,
        conditionLabel,
      }) => {
        weatherEmptyState?.setAttribute("hidden", "");
        weatherErrorState?.setAttribute("hidden", "");
        weatherSummaryPanel?.removeAttribute("hidden");

        if (weatherPanelTemperature) {
          weatherPanelTemperature.textContent = temperature || "Unavailable";
        }

        if (weatherPanelWind) {
          weatherPanelWind.textContent = wind || "Unavailable";
        }

        if (weatherPanelSummary) {
          weatherPanelSummary.textContent = summary || "Unavailable";
        }

        if (weatherPanelSource) {
          weatherPanelSource.textContent = source || "Unavailable";
        }

        if (weatherConditionLabel) {
          weatherConditionLabel.textContent =
            conditionLabels.get(conditionLabel) || "Unknown";
          weatherConditionLabel.removeAttribute("hidden");
        }
      };

      const setLookupLoading = (isLoading) => {
        if (continueRideButton instanceof HTMLButtonElement) {
          continueRideButton.disabled = isLoading;
          continueRideButton.textContent = isLoading ? "Loading details..." : "Continue";
        }
      };

      const setSaveLoading = (isLoading) => {
        if (saveRideButton instanceof HTMLButtonElement) {
          saveRideButton.disabled = isLoading;
          saveRideButton.textContent = isLoading ? "Saving ride entry..." : "Save ride entry";
        }

        if (editRideButton instanceof HTMLButtonElement) {
          editRideButton.disabled = isLoading;
        }
      };

      const setSaveStatus = (variant, heading, message, shouldFocus = false) => {
        if (!saveStatus || !saveStatusHeading || !saveStatusMessage) {
          return;
        }

        saveStatus.classList.remove(
          "usa-alert--error",
          "usa-alert--info",
          "usa-alert--success",
        );
        saveStatus.classList.add(`usa-alert--${variant}`);
        saveStatusHeading.textContent = heading;
        saveStatusMessage.textContent = message;

        if (variant === "error") {
          saveStatus.setAttribute("role", "alert");
        } else {
          saveStatus.setAttribute("role", "status");
          saveStatus.setAttribute("aria-live", "polite");
        }

        saveStatus.removeAttribute("hidden");

        if (shouldFocus && saveStatus instanceof HTMLElement) {
          saveStatus.focus();
        }
      };

      const clearSaveStatus = () => {
        saveStatus?.setAttribute("hidden", "");
        saveStatus?.removeAttribute("role");
        saveStatus?.removeAttribute("aria-live");

        if (saveStatusHeading) {
          saveStatusHeading.textContent = "";
        }

        if (saveStatusMessage) {
          saveStatusMessage.textContent = "";
        }
      };

      const clearWeatherLookupResult = () => {
        setHiddenValue(weatherSummaryInput, "");
        setHiddenValue(weatherTemperatureInput, "");
        setHiddenValue(weatherWindInput, "");
        setHiddenValue(weatherPrecipitationInput, "");
        setHiddenValue(weatherSourceInput, "");
        setHiddenValue(weatherConditionInput, "");
        setWeatherPanelEmpty();
      };

      const clearAddressLookupResult = () => {
        setHiddenValue(addressLabelInput, "");
        setHiddenValue(addressLatitudeInput, "");
        setHiddenValue(addressLongitudeInput, "");
        clearWeatherLookupResult();
      };

      const buildOneLineAddress = () =>
        [
          getTextValue("street-address"),
          getTextValue("address-city"),
          getTextValue("address-state"),
          getTextValue("address-zip"),
        ]
          .filter(Boolean)
          .join(", ");

      const isAddressReadyForLookup = () =>
        addressLookupFieldNames.every((name) => {
          const control = getControl(name);

          return (
            (control instanceof HTMLInputElement ||
              control instanceof HTMLSelectElement) &&
            control.value.trim() &&
            control.validity.valid
          );
        });

      const parseLookupPayload = (payload) => {
        if (typeof payload !== "string") {
          throw new Error("The lookup service returned an invalid response.");
        }

        const parsed = JSON.parse(payload);
        const statusCode =
          typeof parsed.statusCode === "number" ? parsed.statusCode : 502;
        const body =
          typeof parsed.body === "object" && parsed.body !== null
            ? parsed.body
            : {};

        return {
          ok: statusCode >= 200 && statusCode < 300,
          statusCode,
          body,
        };
      };

      const lookupAddress = async () => {
        clearAddressLookupResult();
        setAddressLookupStatus("info", "Looking up the starting address...");
        setWeatherPanelEmpty("Loading public weather data...");
        setLookupLoading(true);

        try {
          const response = await amplifyClient.queries.lookupAddress({
            address: buildOneLineAddress(),
          });

          if (response.errors?.length) {
            throw new Error("Address lookup is unavailable. Try again in a moment.");
          }

          const result = parseLookupPayload(response.data);
          const data = result.body;

          if (
            !result.ok ||
            typeof data.addressLabel !== "string" ||
            typeof data.latitude !== "number" ||
            typeof data.longitude !== "number"
          ) {
            throw new Error(
              typeof data.error === "string"
                ? data.error
                : "We could not find coordinates for that address.",
            );
          }

          setHiddenValue(addressLabelInput, data.addressLabel);
          setHiddenValue(addressLatitudeInput, String(data.latitude));
          setHiddenValue(addressLongitudeInput, String(data.longitude));
          setAddressLookupStatus("success", `Address matched: ${data.addressLabel}`);
          return true;
        } catch (error) {
          const message =
            error instanceof Error
              ? error.message
              : "Address lookup is unavailable. Try again in a moment.";
          setAddressLookupStatus("error", message);
          return false;
        } finally {
          setLookupLoading(false);
        }
      };

      const formatWeatherTemperature = (period) => {
        if (
          typeof period.temperature === "number" &&
          typeof period.temperatureUnit === "string"
        ) {
          return `${period.temperature} °${period.temperatureUnit}`;
        }

        return "";
      };

      const formatWeatherWind = (period) =>
        [period.windSpeed, period.windDirection]
          .filter((value) => typeof value === "string" && value)
          .join(" ");

      const formatWeatherPrecipitation = (period) =>
        typeof period.precipitationChance === "number"
          ? `${period.precipitationChance}% chance`
          : "";

      const deriveConditionLabelFromForecast = ({
        summary,
        temperature,
        wind,
        precipitation,
      }) => {
        const weatherText = [summary, temperature, wind, precipitation]
          .join(" ")
          .toLowerCase();
        const temperatureValue = Number.parseFloat(temperature);
        const windMatch = wind.match(/\d+/);
        const windValue = windMatch ? Number(windMatch[0]) : NaN;

        if (
          weatherText.includes("rain") ||
          weatherText.includes("shower") ||
          weatherText.includes("thunderstorm") ||
          weatherText.includes("snow")
        ) {
          return "wet";
        }

        if (
          weatherText.includes("wind") ||
          (Number.isFinite(windValue) && windValue >= 15)
        ) {
          return "watch_wind";
        }

        if (Number.isFinite(temperatureValue) && temperatureValue >= 85) {
          return "hot";
        }

        if (Number.isFinite(temperatureValue) && temperatureValue <= 40) {
          return "cold";
        }

        if (summary) {
          return "favorable";
        }

        return "unknown";
      };

      const lookupWeatherForecast = async () => {
        clearWeatherLookupResult();
        setWeatherLookupStatus("info", "Loading the nearest NWS forecast...");
        setWeatherPanelEmpty("Loading public weather data...");
        setLookupLoading(true);

        try {
          const latitude = getTextValue("address-latitude");
          const longitude = getTextValue("address-longitude");
          const response = await amplifyClient.queries.lookupWeatherForecast({
            latitude,
            longitude,
          });

          if (response.errors?.length) {
            throw new Error("Weather forecast is unavailable. Try again in a moment.");
          }

          const result = parseLookupPayload(response.data);
          const data = result.body;
          const period = data.period;

          if (!result.ok || typeof period !== "object" || period === null) {
            throw new Error(
              typeof data.error === "string"
                ? data.error
                : "Weather forecast is unavailable. Try again in a moment.",
            );
          }

          const summary =
            typeof period.shortForecast === "string"
              ? period.shortForecast
              : "Forecast loaded";
          const temperature = formatWeatherTemperature(period);
          const wind = formatWeatherWind(period);
          const precipitation = formatWeatherPrecipitation(period);
          const source =
            typeof data.source === "string" ? data.source : "National Weather Service";
          const conditionLabel = deriveConditionLabelFromForecast({
            summary,
            temperature,
            wind,
            precipitation,
          });

          setHiddenValue(weatherSummaryInput, summary);
          setHiddenValue(weatherTemperatureInput, temperature);
          setHiddenValue(weatherWindInput, wind);
          setHiddenValue(weatherPrecipitationInput, precipitation);
          setHiddenValue(weatherSourceInput, source);
          setHiddenValue(weatherConditionInput, conditionLabel);
          setWeatherPanelSummary({
            temperature,
            wind,
            summary,
            source,
            conditionLabel,
          });
          setWeatherLookupStatus(
            "success",
            `NWS forecast loaded: ${[temperature, summary].filter(Boolean).join(", ")}`,
          );
        } catch (error) {
          const message =
            error instanceof Error
              ? error.message
              : "Weather forecast is unavailable. Try again in a moment.";
          setWeatherLookupStatus("warning", message);
          setWeatherPanelError(message);
        } finally {
          setLookupLoading(false);
        }
      };

      const lookupRideConditions = async () => {
        const currentAddress = buildOneLineAddress();

        if (!isAddressReadyForLookup() || currentAddress === lastRequestedAddress) {
          return;
        }

        lastRequestedAddress = currentAddress;
        const didLookupAddress = await lookupAddress();

        if (didLookupAddress) {
          await lookupWeatherForecast();
        }
      };

      const scheduleRideConditionsLookup = () => {
        window.clearTimeout(addressLookupTimer);

        if (!isAddressReadyForLookup()) {
          lastRequestedAddress = "";
          return;
        }

        addressLookupTimer = window.setTimeout(() => {
          void lookupRideConditions();
        }, 600);
      };

      const getEffortValue = () => {
        const checkedEffort = journalForm.querySelector(
          'input[name="effort"]:checked',
        );

        if (checkedEffort instanceof HTMLInputElement) {
          return effortLabels.get(checkedEffort.value) || checkedEffort.value;
        }

        return "";
      };

      const getEffortInputValue = () => {
        const checkedEffort = journalForm.querySelector(
          'input[name="effort"]:checked',
        );

        if (checkedEffort instanceof HTMLInputElement) {
          return checkedEffort.value;
        }

        return "";
      };

      const deriveConditionLabel = () =>
        getTextValue("weather-condition") ||
        deriveConditionLabelFromForecast({
          summary: getTextValue("weather-summary"),
          temperature: getTextValue("weather-temperature"),
          wind: getTextValue("weather-wind"),
          precipitation: getTextValue("weather-precipitation"),
        });

      const buildRideEntryInput = () => ({
        rideDate: getTextValue("ride-date"),
        addressLabel: getTextValue("address-label") || buildOneLineAddress(),
        latitude: Number(getTextValue("address-latitude")),
        longitude: Number(getTextValue("address-longitude")),
        locationSource: "address",
        distanceMiles: Number(getTextValue("ride-distance")),
        durationMinutes: Number(getTextValue("ride-duration")),
        effort: getEffortInputValue(),
        rideNotes: getTextValue("ride-notes") || null,
        weatherNotes: getTextValue("weather-notes") || null,
        weatherSummary: getTextValue("weather-summary") || "Unavailable",
        weatherTemperature: getTextValue("weather-temperature") || null,
        windSpeed: getTextValue("weather-wind") || null,
        precipitationSummary: getTextValue("weather-precipitation") || null,
        weatherSource: getTextValue("weather-source") || "Not captured",
        weatherCapturedAt: new Date().toISOString(),
        conditionLabel: deriveConditionLabel(),
      });

      const saveRideEntry = async () => {
        clearSaveStatus();
        setSaveLoading(true);
        setSaveStatus("info", "Saving ride entry", "Your confirmed ride is being saved.");

        try {
          const response = await amplifyClient.models.RideEntry.create(
            buildRideEntryInput(),
          );

          if (response.errors?.length) {
            throw new Error("Ride entry could not be saved. Try again in a moment.");
          }

          setSaveStatus(
            "success",
            "Ride entry saved",
            "Your ride entry was saved and is ready for the saved rides list.",
            true,
          );
        } catch (error) {
          const message =
            error instanceof Error
              ? error.message
              : "Ride entry could not be saved. Try again in a moment.";
          setSaveStatus("error", "Ride entry was not saved", message, true);
        } finally {
          setSaveLoading(false);
        }
      };

      const formatDate = (value) => {
        const [year, month, day] = value.split("-").map(Number);

        if (!year || !month || !day) {
          return value;
        }

        return new Intl.DateTimeFormat("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
          timeZone: "UTC",
        }).format(new Date(Date.UTC(year, month - 1, day)));
      };

      const formatDistance = (value) => {
        const distance = Number(value);

        if (!Number.isFinite(distance)) {
          return value;
        }

        return `${distance.toLocaleString("en-US", {
          maximumFractionDigits: 1,
          minimumFractionDigits: distance % 1 === 0 ? 0 : 1,
        })} miles`;
      };

      const formatDuration = (value) => {
        const duration = Number(value);

        if (!Number.isFinite(duration)) {
          return value;
        }

        return `${duration.toLocaleString("en-US")} ${
          duration === 1 ? "minute" : "minutes"
        }`;
      };

      const getReviewItems = () => [
        ["Ride date", formatDate(getTextValue("ride-date"))],
        ["Starting address", getTextValue("address-label")],
        ["Latitude", getTextValue("address-latitude")],
        ["Longitude", getTextValue("address-longitude")],
        ["City", getTextValue("address-city")],
        ["State", getTextValue("address-state")],
        ["ZIP code", getTextValue("address-zip")],
        ["Distance", formatDistance(getTextValue("ride-distance"))],
        ["Duration", formatDuration(getTextValue("ride-duration"))],
        ["Effort", getEffortValue()],
        ["Forecast", getTextValue("weather-summary") || "Unavailable"],
        ["Temperature", getTextValue("weather-temperature") || "Unavailable"],
        ["Wind", getTextValue("weather-wind") || "Unavailable"],
        [
          "Condition label",
          conditionLabels.get(deriveConditionLabel()) || "Unknown",
        ],
        [
          "Precipitation",
          getTextValue("weather-precipitation") || "Unavailable",
        ],
        ["Weather source", getTextValue("weather-source") || "Unavailable"],
        ["Weather notes", getTextValue("weather-notes") || "None entered"],
        ["Ride notes", getTextValue("ride-notes") || "None entered"],
      ];

      const showForm = () => {
        journalReview?.setAttribute("hidden", "");
        journalForm.removeAttribute("hidden");
        journalForm.dataset.entryStep = "form";
      };

      const showReview = () => {
        if (!journalReview || !reviewList) {
          return;
        }

        reviewList.replaceChildren();

        getReviewItems().forEach(([label, value]) => {
          const term = document.createElement("dt");
          const detail = document.createElement("dd");

          term.textContent = label;
          detail.textContent = value;
          reviewList.append(term, detail);
        });

        journalForm.setAttribute("hidden", "");
        journalForm.dataset.entryStep = "review";
        journalReview.removeAttribute("hidden");
        clearSaveStatus();

        if (reviewHeading instanceof HTMLElement) {
          reviewHeading.focus();
        }
      };

      const clearErrors = () => {
        validationSummary?.setAttribute("hidden", "");
        validationList?.replaceChildren();

        journalForm.querySelectorAll(".app-field-error").forEach((error) => {
          error.remove();
        });

        formControls.forEach((control) => {
          const describedBy = originalDescriptions.get(control.id);

          control.removeAttribute("aria-invalid");
          control.classList.remove("usa-input--error", "usa-select--error");
          getFormGroup(control)?.classList.remove("usa-form-group--error");

          if (describedBy) {
            control.setAttribute("aria-describedby", describedBy);
          } else {
            control.removeAttribute("aria-describedby");
          }
        });
      };

      const showErrors = (invalidControls) => {
        if (!validationSummary || !validationList) {
          return;
        }

        clearErrors();

        invalidControls.forEach((control) => {
          const fieldKey = getFieldKey(control);
          const errorId = `${fieldKey}-error`;
          const message = getErrorMessage(control);
          const formGroup = getFormGroup(control);
          const errorMessage = document.createElement("span");
          const summaryItem = document.createElement("li");
          const summaryLink = document.createElement("a");
          const existingDescription = originalDescriptions.get(control.id);
          const describedBy = [errorId, existingDescription].filter(Boolean).join(" ");

          errorMessage.className = "usa-error-message app-field-error";
          errorMessage.id = errorId;
          errorMessage.textContent = message;

          formGroup?.classList.add("usa-form-group--error");
          control.setAttribute("aria-invalid", "true");
          control.setAttribute("aria-describedby", describedBy);
          if (control instanceof HTMLSelectElement) {
            control.classList.add("usa-select--error");
          } else if (control.type !== "radio") {
            control.classList.add("usa-input--error");
          }

          if (control.name === "effort") {
            const legend = formGroup?.querySelector("legend");
            legend?.insertAdjacentElement("afterend", errorMessage);
          } else {
            control.insertAdjacentElement("beforebegin", errorMessage);
          }

          summaryLink.href = `#${control.id}`;
          summaryLink.textContent = `${getFieldLabel(control)}: ${message}`;
          summaryItem.append(summaryLink);
          validationList.append(summaryItem);
        });

        validationSummary.removeAttribute("hidden");
        validationSummary.focus();
      };

      journalForm.addEventListener("submit", async (event) => {
        const invalidControls = getInvalidControls();

        if (invalidControls.length === 0) {
          clearErrors();

          if (journalForm.dataset.entryStep === "confirmed") {
            return;
          }

          event.preventDefault();
          const didLookupAddress = await lookupAddress();

          if (didLookupAddress) {
            await lookupWeatherForecast();
            showReview();
          }
          return;
        }

        event.preventDefault();
        showForm();
        showErrors(invalidControls);
      });

      journalForm.addEventListener("input", (event) => {
        if (
          event.target instanceof HTMLInputElement ||
          event.target instanceof HTMLTextAreaElement
        ) {
          clearErrors();

          if (addressFieldNames.has(event.target.name)) {
            clearAddressLookupResult();
            clearAddressLookupStatus();
            clearWeatherLookupStatus();
            scheduleRideConditionsLookup();
          }
        }
      });

      journalForm.addEventListener("change", (event) => {
        if (
          event.target instanceof HTMLSelectElement ||
          event.target instanceof HTMLInputElement
        ) {
          clearErrors();

          if (addressFieldNames.has(event.target.name)) {
            clearAddressLookupResult();
            clearAddressLookupStatus();
            clearWeatherLookupStatus();
            scheduleRideConditionsLookup();
          }
        }
      });

      scheduleRideConditionsLookup();

      editRideButton?.addEventListener("click", () => {
        showForm();
        document.querySelector("#journal-form-heading")?.focus();
      });

      saveRideButton?.addEventListener("click", async () => {
        await saveRideEntry();
      });
    }
  </script>
</UswdsLayout>
