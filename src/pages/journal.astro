---
import UswdsLayout from "../layouts/UswdsLayout.astro";
---

<UswdsLayout
  title="Journal | Ride Conditions"
  description="Start and review ride journal entries in Ride Conditions."
>
  <section class="usa-section app-intro">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-8">
          <p class="usa-intro">Ride journal</p>
          <h1>Capture a ride entry.</h1>
          <p>
            Record the basics of a ride, including location notes and conditions
            that can later be paired with public weather data.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="usa-section usa-section--light" aria-labelledby="journal-form-heading">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-8 desktop:grid-col-6">
          <h2 id="journal-form-heading">Ride details</h2>
          <form
            class="usa-form usa-form--large"
            action="/rides/"
            method="get"
            novalidate
            data-journal-form
          >
            <p class="usa-hint">
              Required fields are marked with <abbr title="required">*</abbr>.
            </p>
            <div
              class="usa-alert usa-alert--error app-validation-summary"
              id="journal-validation-summary"
              role="alert"
              tabindex="-1"
              hidden
            >
              <div class="usa-alert__body">
                <h2 class="usa-alert__heading" id="journal-validation-heading">
                  Correct the highlighted fields.
                </h2>
                <ul class="usa-list" id="journal-validation-list"></ul>
              </div>
            </div>

            <fieldset class="usa-fieldset">
              <legend class="usa-legend usa-legend--large">When and where</legend>

              <label class="usa-label" for="ride-date">
                Ride date <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input"
                id="ride-date"
                name="ride-date"
                type="date"
                required
              />

              <label class="usa-label" for="street-address">
                Starting street address <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input"
                id="street-address"
                name="street-address"
                type="text"
                autocomplete="street-address"
                required
              />

              <label class="usa-label" for="address-city">
                City <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input"
                id="address-city"
                name="address-city"
                type="text"
                autocomplete="address-level2"
                required
              />

              <label class="usa-label" for="address-state">
                State <abbr title="required">*</abbr>
              </label>
              <select
                class="usa-select"
                id="address-state"
                name="address-state"
                autocomplete="address-level1"
                required
              >
                <option value="">- Select -</option>
                <option value="AL">Alabama</option>
                <option value="AK">Alaska</option>
                <option value="AZ">Arizona</option>
                <option value="AR">Arkansas</option>
                <option value="CA">California</option>
                <option value="CO">Colorado</option>
                <option value="CT">Connecticut</option>
                <option value="DE">Delaware</option>
                <option value="DC">District of Columbia</option>
                <option value="FL">Florida</option>
                <option value="GA">Georgia</option>
                <option value="HI">Hawaii</option>
                <option value="ID">Idaho</option>
                <option value="IL">Illinois</option>
                <option value="IN">Indiana</option>
                <option value="IA">Iowa</option>
                <option value="KS">Kansas</option>
                <option value="KY">Kentucky</option>
                <option value="LA">Louisiana</option>
                <option value="ME">Maine</option>
                <option value="MD">Maryland</option>
                <option value="MA">Massachusetts</option>
                <option value="MI">Michigan</option>
                <option value="MN">Minnesota</option>
                <option value="MS">Mississippi</option>
                <option value="MO">Missouri</option>
                <option value="MT">Montana</option>
                <option value="NE">Nebraska</option>
                <option value="NV">Nevada</option>
                <option value="NH">New Hampshire</option>
                <option value="NJ">New Jersey</option>
                <option value="NM">New Mexico</option>
                <option value="NY">New York</option>
                <option value="NC">North Carolina</option>
                <option value="ND">North Dakota</option>
                <option value="OH">Ohio</option>
                <option value="OK">Oklahoma</option>
                <option value="OR">Oregon</option>
                <option value="PA">Pennsylvania</option>
                <option value="RI">Rhode Island</option>
                <option value="SC">South Carolina</option>
                <option value="SD">South Dakota</option>
                <option value="TN">Tennessee</option>
                <option value="TX">Texas</option>
                <option value="UT">Utah</option>
                <option value="VT">Vermont</option>
                <option value="VA">Virginia</option>
                <option value="WA">Washington</option>
                <option value="WV">West Virginia</option>
                <option value="WI">Wisconsin</option>
                <option value="WY">Wyoming</option>
              </select>

              <label class="usa-label" for="address-zip">
                ZIP code <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input usa-input--medium"
                id="address-zip"
                name="address-zip"
                type="text"
                inputmode="numeric"
                autocomplete="postal-code"
                pattern="[0-9]{5}(-[0-9]{4})?"
                required
              />
            </fieldset>

            <fieldset class="usa-fieldset margin-top-4">
              <legend class="usa-legend usa-legend--large">Ride activity</legend>

              <label class="usa-label" for="ride-distance">
                Distance in miles <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input usa-input--small"
                id="ride-distance"
                name="ride-distance"
                type="number"
                inputmode="decimal"
                min="0"
                step="0.1"
                required
              />

              <label class="usa-label" for="ride-duration">
                Duration in minutes <abbr title="required">*</abbr>
              </label>
              <input
                class="usa-input usa-input--small"
                id="ride-duration"
                name="ride-duration"
                type="number"
                inputmode="numeric"
                min="1"
                step="1"
                required
              />
            </fieldset>

            <fieldset class="usa-fieldset margin-top-4">
              <legend class="usa-legend usa-legend--large">
                Effort <abbr title="required">*</abbr>
              </legend>
              <div class="usa-radio">
                <input
                  class="usa-radio__input"
                  id="effort-easy"
                  name="effort"
                  type="radio"
                  value="easy"
                  required
                />
                <label class="usa-radio__label" for="effort-easy">Easy</label>
              </div>
              <div class="usa-radio">
                <input
                  class="usa-radio__input"
                  id="effort-moderate"
                  name="effort"
                  type="radio"
                  value="moderate"
                />
                <label class="usa-radio__label" for="effort-moderate">Moderate</label>
              </div>
              <div class="usa-radio">
                <input
                  class="usa-radio__input"
                  id="effort-hard"
                  name="effort"
                  type="radio"
                  value="hard"
                />
                <label class="usa-radio__label" for="effort-hard">Hard</label>
              </div>
            </fieldset>

            <fieldset class="usa-fieldset margin-top-4">
              <legend class="usa-legend usa-legend--large">Notes</legend>

              <label class="usa-label" for="weather-notes">Weather notes</label>
              <div class="usa-hint" id="weather-notes-hint">
                Add wind, temperature, visibility, or road condition details.
              </div>
              <textarea
                class="usa-textarea"
                id="weather-notes"
                name="weather-notes"
                aria-describedby="weather-notes-hint"
              ></textarea>

              <label class="usa-label" for="ride-notes">Ride notes</label>
              <div class="usa-hint" id="ride-notes-hint">
                Add route highlights, stops, comfort notes, or anything to remember.
              </div>
              <textarea
                class="usa-textarea"
                id="ride-notes"
                name="ride-notes"
                aria-describedby="ride-notes-hint"
              ></textarea>
            </fieldset>

            <button class="usa-button margin-top-4" type="submit">
              Save ride entry
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    const journalForm = document.querySelector("[data-journal-form]");

    if (journalForm instanceof HTMLFormElement) {
      const validationSummary = journalForm.querySelector(
        "#journal-validation-summary",
      );
      const validationList = journalForm.querySelector("#journal-validation-list");
      const formControls = Array.from(
        journalForm.querySelectorAll("input, select, textarea"),
      ).filter(
        (control) =>
          control instanceof HTMLInputElement ||
          control instanceof HTMLSelectElement ||
          control instanceof HTMLTextAreaElement,
      );

      const fieldLabels = new Map([
        ["ride-date", "Ride date"],
        ["street-address", "Starting street address"],
        ["address-city", "City"],
        ["address-state", "State"],
        ["address-zip", "ZIP code"],
        ["ride-distance", "Distance in miles"],
        ["ride-duration", "Duration in minutes"],
        ["effort", "Effort"],
      ]);

      const requiredMessages = new Map([
        ["address-state", "Select the state where the ride started."],
        ["effort", "Select how hard the ride felt."],
      ]);

      const invalidMessages = new Map([
        ["address-zip", "Enter a 5-digit ZIP code, or ZIP+4."],
        ["ride-distance", "Enter a distance of 0 miles or more, using tenths of a mile if needed."],
        ["ride-duration", "Enter a whole number of minutes greater than 0."],
      ]);

      const originalDescriptions = new Map(
        formControls.map((control) => [
          control.id,
          control.getAttribute("aria-describedby") || "",
        ]),
      );

      const getFieldKey = (control) =>
        control.name === "effort" ? "effort" : control.id;

      const getFieldLabel = (control) => {
        const fieldKey = getFieldKey(control);
        return (
          fieldLabels.get(fieldKey) ||
          control.labels?.[0]?.textContent?.replace("*", "").trim() ||
          "This field"
        );
      };

      const getErrorMessage = (control) => {
        const fieldKey = getFieldKey(control);

        if (control.validity.valueMissing) {
          return (
            requiredMessages.get(fieldKey) ||
            `Enter ${getFieldLabel(control).toLowerCase()}.`
          );
        }

        if (
          control.validity.rangeUnderflow ||
          control.validity.stepMismatch ||
          control.validity.badInput ||
          control.validity.patternMismatch
        ) {
          return (
            invalidMessages.get(fieldKey) ||
            `Enter a valid ${getFieldLabel(control).toLowerCase()}.`
          );
        }

        return (
          control.validationMessage ||
          `Enter a valid ${getFieldLabel(control).toLowerCase()}.`
        );
      };

      const getFormGroup = (control) => {
        if (control.name === "effort") {
          return control.closest("fieldset");
        }

        return control.closest(".usa-form-group") || control.parentElement;
      };

      const getInvalidControls = () => {
        const invalidControls = [];
        const seenFields = new Set();

        for (const control of formControls) {
          const fieldKey = getFieldKey(control);

          if (seenFields.has(fieldKey) || control.validity.valid) {
            continue;
          }

          seenFields.add(fieldKey);
          invalidControls.push(control);
        }

        return invalidControls;
      };

      const clearErrors = () => {
        validationSummary?.setAttribute("hidden", "");
        validationList?.replaceChildren();

        journalForm.querySelectorAll(".app-field-error").forEach((error) => {
          error.remove();
        });

        formControls.forEach((control) => {
          const describedBy = originalDescriptions.get(control.id);

          control.removeAttribute("aria-invalid");
          control.classList.remove("usa-input--error", "usa-select--error");
          getFormGroup(control)?.classList.remove("usa-form-group--error");

          if (describedBy) {
            control.setAttribute("aria-describedby", describedBy);
          } else {
            control.removeAttribute("aria-describedby");
          }
        });
      };

      const showErrors = (invalidControls) => {
        if (!validationSummary || !validationList) {
          return;
        }

        clearErrors();

        invalidControls.forEach((control) => {
          const fieldKey = getFieldKey(control);
          const errorId = `${fieldKey}-error`;
          const message = getErrorMessage(control);
          const formGroup = getFormGroup(control);
          const errorMessage = document.createElement("span");
          const summaryItem = document.createElement("li");
          const summaryLink = document.createElement("a");
          const existingDescription = originalDescriptions.get(control.id);
          const describedBy = [errorId, existingDescription].filter(Boolean).join(" ");

          errorMessage.className = "usa-error-message app-field-error";
          errorMessage.id = errorId;
          errorMessage.textContent = message;

          formGroup?.classList.add("usa-form-group--error");
          control.setAttribute("aria-invalid", "true");
          control.setAttribute("aria-describedby", describedBy);
          if (control instanceof HTMLSelectElement) {
            control.classList.add("usa-select--error");
          } else if (control.type !== "radio") {
            control.classList.add("usa-input--error");
          }

          if (control.name === "effort") {
            const legend = formGroup?.querySelector("legend");
            legend?.insertAdjacentElement("afterend", errorMessage);
          } else {
            control.insertAdjacentElement("beforebegin", errorMessage);
          }

          summaryLink.href = `#${control.id}`;
          summaryLink.textContent = `${getFieldLabel(control)}: ${message}`;
          summaryItem.append(summaryLink);
          validationList.append(summaryItem);
        });

        validationSummary.removeAttribute("hidden");
        validationSummary.focus();
      };

      journalForm.addEventListener("submit", (event) => {
        const invalidControls = getInvalidControls();

        if (invalidControls.length === 0) {
          clearErrors();
          return;
        }

        event.preventDefault();
        showErrors(invalidControls);
      });

      journalForm.addEventListener("input", (event) => {
        if (
          event.target instanceof HTMLInputElement ||
          event.target instanceof HTMLTextAreaElement
        ) {
          clearErrors();
        }
      });

      journalForm.addEventListener("change", (event) => {
        if (
          event.target instanceof HTMLSelectElement ||
          event.target instanceof HTMLInputElement
        ) {
          clearErrors();
        }
      });
    }
  </script>
</UswdsLayout>
