---
import UswdsLayout from "../layouts/UswdsLayout.astro";
---

<UswdsLayout
  title="Saved rides | Good Looks"
  description="Review saved ride entries in Good Looks."
>
  <section class="usa-section app-intro">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-8">
          <p class="usa-intro">Saved rides</p>
          <h1>Return to logged rides.</h1>
          <p>
            Browse ride entries after they are saved, including route,
            effort, notes, and recorded ride context.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="usa-section usa-section--light" aria-labelledby="saved-rides-heading">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-10 desktop:grid-col-8">
          <div class="display-flex flex-align-center flex-justify">
            <h2 id="saved-rides-heading" class="margin-y-0">Ride entries</h2>
            <a class="usa-button usa-button--outline" href="/journal/">
              Add ride
            </a>
          </div>

          <div
            class="usa-alert usa-alert--info usa-alert--slim margin-top-4"
            data-rides-loading
            role="status"
            aria-live="polite"
          >
            <div class="usa-alert__body">
              <p class="usa-alert__text">Loading saved rides...</p>
            </div>
          </div>

          <div
            class="usa-alert usa-alert--error margin-top-4"
            data-rides-error
            role="alert"
            hidden
          >
            <div class="usa-alert__body">
              <h3 class="usa-alert__heading">Saved rides could not load</h3>
              <p class="usa-alert__text">
                Refresh the page or try again in a moment.
              </p>
            </div>
          </div>

          <div
            class="usa-alert margin-top-4"
            data-rides-action-status
            tabindex="-1"
            hidden
          >
            <div class="usa-alert__body">
              <h3 class="usa-alert__heading" data-rides-action-heading></h3>
              <p class="usa-alert__text" data-rides-action-message></p>
            </div>
          </div>

          <div
            class="usa-alert usa-alert--info margin-top-4"
            data-rides-empty
            hidden
          >
            <div class="usa-alert__body">
              <h3 class="usa-alert__heading">No saved rides yet</h3>
              <p class="usa-alert__text">
                Saved ride entries will appear here after they are added from the
                journal.
              </p>
            </div>
          </div>

          <ul class="usa-card-group app-ride-list margin-top-4" data-rides-list></ul>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { amplifyClient } from "../lib/amplifyClient";

    const ridesList = document.querySelector("[data-rides-list]");
    const loadingState = document.querySelector("[data-rides-loading]");
    const errorState = document.querySelector("[data-rides-error]");
    const emptyState = document.querySelector("[data-rides-empty]");
    const actionStatus = document.querySelector("[data-rides-action-status]");
    const actionStatusHeading = document.querySelector(
      "[data-rides-action-heading]",
    );
    const actionStatusMessage = document.querySelector(
      "[data-rides-action-message]",
    );

    const effortLabels = new Map([
      ["easy", "Easy"],
      ["moderate", "Moderate"],
      ["hard", "Hard"],
    ]);

    const setHidden = (element: Element | null, isHidden: boolean) => {
      if (isHidden) {
        element?.setAttribute("hidden", "");
      } else {
        element?.removeAttribute("hidden");
      }
    };

    const setActionStatus = (
      variant: "success" | "error" | "info",
      heading: string,
      message: string,
      shouldFocus = true,
    ) => {
      if (!actionStatus || !actionStatusHeading || !actionStatusMessage) {
        return;
      }

      actionStatus.classList.remove(
        "usa-alert--error",
        "usa-alert--info",
        "usa-alert--success",
      );
      actionStatus.classList.add(`usa-alert--${variant}`);
      actionStatusHeading.textContent = heading;
      actionStatusMessage.textContent = message;
      actionStatus.setAttribute("role", variant === "error" ? "alert" : "status");
      actionStatus.setAttribute(
        "aria-live",
        variant === "error" ? "assertive" : "polite",
      );
      actionStatus.removeAttribute("hidden");

      if (shouldFocus && actionStatus instanceof HTMLElement) {
        actionStatus.focus();
      }
    };

    const clearActionStatus = () => {
      actionStatus?.setAttribute("hidden", "");
      actionStatus?.removeAttribute("role");
      actionStatus?.removeAttribute("aria-live");

      if (actionStatusHeading) {
        actionStatusHeading.textContent = "";
      }

      if (actionStatusMessage) {
        actionStatusMessage.textContent = "";
      }
    };

    const formatDate = (value: string | null | undefined) => {
      if (!value) {
        return "Date unavailable";
      }

      const [year, month, day] = value.split("-").map(Number);

      if (!year || !month || !day) {
        return value;
      }

      return new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
        timeZone: "UTC",
      }).format(new Date(Date.UTC(year, month - 1, day)));
    };

    const formatDistance = (value: number | null | undefined) => {
      if (typeof value !== "number" || !Number.isFinite(value)) {
        return "Distance unavailable";
      }

      return `${value.toLocaleString("en-US", {
        maximumFractionDigits: 1,
        minimumFractionDigits: value % 1 === 0 ? 0 : 1,
      })} mi`;
    };

    const formatEffort = (value: string | null | undefined) =>
      value ? effortLabels.get(value) || value : "Effort unavailable";

    const formatNotesPreview = (
      rideNotes: string | null | undefined,
      weatherNotes: string | null | undefined,
    ) => {
      const notes = [rideNotes, weatherNotes]
        .map((note) => note?.trim())
        .filter(Boolean)
        .join(" ");

      if (!notes) {
        return "No notes entered.";
      }

      return notes.length > 140 ? `${notes.slice(0, 137).trim()}...` : notes;
    };

    const formatWeatherSnapshot = (entry: {
      weatherSummary?: string | null;
      weatherTemperature?: string | null;
      windSpeed?: string | null;
      precipitationSummary?: string | null;
    }) =>
      [
        entry.weatherTemperature,
        entry.weatherSummary,
        entry.windSpeed ? `Wind ${entry.windSpeed}` : "",
        entry.precipitationSummary,
      ]
        .filter((value) => typeof value === "string" && value.trim())
        .join(" | ") || "Weather unavailable";

    const createMetaItem = (label: string, value: string) => {
      const item = document.createElement("div");
      const term = document.createElement("dt");
      const detail = document.createElement("dd");

      term.textContent = label;
      detail.textContent = value;
      item.append(term, detail);

      return item;
    };

    const createField = (
      labelText: string,
      control: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement,
    ) => {
      const wrapper = document.createElement("div");
      const label = document.createElement("label");

      wrapper.className = "usa-form-group";
      label.className = "usa-label";
      label.htmlFor = control.id;
      label.textContent = labelText;
      wrapper.append(label, control);

      return wrapper;
    };

    const setCardBusy = (card: HTMLElement, isBusy: boolean) => {
      card.querySelectorAll("button, input, select, textarea").forEach((control) => {
        if (
          control instanceof HTMLButtonElement ||
          control instanceof HTMLInputElement ||
          control instanceof HTMLSelectElement ||
          control instanceof HTMLTextAreaElement
        ) {
          control.disabled = isBusy;
        }
      });
    };

    const deleteRideEntry = async (entry: { id?: string; addressLabel?: string | null }) => {
      if (!entry.id) {
        setActionStatus("error", "Ride entry was not deleted", "This ride entry is missing an ID.");
        return;
      }

      const label = entry.addressLabel || "this ride";
      const shouldDelete = window.confirm(
        `Delete ${label}? This removes the saved ride entry from the demo database.`,
      );

      if (!shouldDelete) {
        return;
      }

      clearActionStatus();

      try {
        const response = await amplifyClient.models.RideEntry.delete({ id: entry.id });

        if (response.errors?.length) {
          throw new Error("Ride entry could not be deleted. Try again in a moment.");
        }

        setActionStatus("success", "Ride entry deleted", "The saved ride entry was removed.");
        await loadRideEntries(false);
      } catch (error) {
        const message =
          error instanceof Error
            ? error.message
            : "Ride entry could not be deleted. Try again in a moment.";
        setActionStatus("error", "Ride entry was not deleted", message);
      }
    };

    const renderEditForm = (
      card: HTMLElement,
      entry: {
        id?: string;
        rideDate?: string | null;
        addressLabel?: string | null;
        latitude?: number | null;
        longitude?: number | null;
        distanceMiles?: number | null;
        durationMinutes?: number | null;
        effort?: string | null;
        rideNotes?: string | null;
        weatherNotes?: string | null;
      },
      renderView: () => void,
    ) => {
      const form = document.createElement("form");
      const heading = document.createElement("h4");
      const actions = document.createElement("div");
      const saveButton = document.createElement("button");
      const cancelButton = document.createElement("button");

      const idPrefix = `ride-${entry.id || Math.random().toString(36).slice(2)}`;
      const rideDate = document.createElement("input");
      const addressLabel = document.createElement("input");
      const latitude = document.createElement("input");
      const longitude = document.createElement("input");
      const distanceMiles = document.createElement("input");
      const durationMinutes = document.createElement("input");
      const effort = document.createElement("select");
      const rideNotes = document.createElement("textarea");
      const weatherNotes = document.createElement("textarea");

      form.className = "usa-form usa-form--large app-ride-edit-form";
      heading.className = "usa-card__heading";
      heading.textContent = "Edit saved ride";

      rideDate.className = "usa-input";
      rideDate.id = `${idPrefix}-date`;
      rideDate.name = "rideDate";
      rideDate.type = "date";
      rideDate.required = true;
      rideDate.value = entry.rideDate || "";

      addressLabel.className = "usa-input";
      addressLabel.id = `${idPrefix}-address`;
      addressLabel.name = "addressLabel";
      addressLabel.type = "text";
      addressLabel.required = true;
      addressLabel.value = entry.addressLabel || "";

      latitude.className = "usa-input usa-input--medium";
      latitude.id = `${idPrefix}-latitude`;
      latitude.name = "latitude";
      latitude.type = "number";
      latitude.min = "-90";
      latitude.max = "90";
      latitude.step = "any";
      latitude.required = true;
      latitude.value = typeof entry.latitude === "number" ? String(entry.latitude) : "";

      longitude.className = "usa-input usa-input--medium";
      longitude.id = `${idPrefix}-longitude`;
      longitude.name = "longitude";
      longitude.type = "number";
      longitude.min = "-180";
      longitude.max = "180";
      longitude.step = "any";
      longitude.required = true;
      longitude.value =
        typeof entry.longitude === "number" ? String(entry.longitude) : "";

      distanceMiles.className = "usa-input usa-input--small";
      distanceMiles.id = `${idPrefix}-distance`;
      distanceMiles.name = "distanceMiles";
      distanceMiles.type = "number";
      distanceMiles.min = "0";
      distanceMiles.step = "0.1";
      distanceMiles.required = true;
      distanceMiles.value =
        typeof entry.distanceMiles === "number" ? String(entry.distanceMiles) : "";

      durationMinutes.className = "usa-input usa-input--small";
      durationMinutes.id = `${idPrefix}-duration`;
      durationMinutes.name = "durationMinutes";
      durationMinutes.type = "number";
      durationMinutes.min = "1";
      durationMinutes.step = "1";
      durationMinutes.value =
        typeof entry.durationMinutes === "number"
          ? String(entry.durationMinutes)
          : "";

      effort.className = "usa-select";
      effort.id = `${idPrefix}-effort`;
      effort.name = "effort";
      [
        ["", "- Select -"],
        ["easy", "Easy"],
        ["moderate", "Moderate"],
        ["hard", "Hard"],
      ].forEach(([value, label]) => {
        const option = document.createElement("option");
        option.value = value;
        option.textContent = label;
        effort.append(option);
      });
      effort.value = entry.effort || "";

      rideNotes.className = "usa-textarea";
      rideNotes.id = `${idPrefix}-ride-notes`;
      rideNotes.name = "rideNotes";
      rideNotes.value = entry.rideNotes || "";

      weatherNotes.className = "usa-textarea";
      weatherNotes.id = `${idPrefix}-weather-notes`;
      weatherNotes.name = "weatherNotes";
      weatherNotes.value = entry.weatherNotes || "";

      actions.className = "app-ride-actions margin-top-3";
      saveButton.className = "usa-button";
      saveButton.type = "submit";
      saveButton.textContent = "Save changes";
      cancelButton.className = "usa-button usa-button--outline";
      cancelButton.type = "button";
      cancelButton.textContent = "Cancel";
      actions.append(saveButton, cancelButton);

      form.append(
        heading,
        createField("Ride date", rideDate),
        createField("Address label", addressLabel),
        createField("Latitude", latitude),
        createField("Longitude", longitude),
        createField("Distance in miles", distanceMiles),
        createField("Duration in minutes", durationMinutes),
        createField("Effort", effort),
        createField("Ride notes", rideNotes),
        createField("Weather notes", weatherNotes),
        actions,
      );

      cancelButton.addEventListener("click", () => {
        renderView();
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!entry.id) {
          setActionStatus("error", "Ride entry was not updated", "This ride entry is missing an ID.");
          return;
        }

        if (!form.reportValidity()) {
          return;
        }

        setCardBusy(card, true);
        clearActionStatus();

        try {
          const response = await amplifyClient.models.RideEntry.update({
            id: entry.id,
            rideDate: rideDate.value,
            addressLabel: addressLabel.value.trim(),
            latitude: Number(latitude.value),
            longitude: Number(longitude.value),
            distanceMiles: Number(distanceMiles.value),
            durationMinutes: durationMinutes.value ? Number(durationMinutes.value) : null,
            effort: effort.value || null,
            rideNotes: rideNotes.value.trim() || null,
            weatherNotes: weatherNotes.value.trim() || null,
          });

          if (response.errors?.length) {
            throw new Error("Ride entry could not be updated. Try again in a moment.");
          }

          setActionStatus("success", "Ride entry updated", "The saved ride entry was updated.");
          await loadRideEntries(false);
        } catch (error) {
          const message =
            error instanceof Error
              ? error.message
              : "Ride entry could not be updated. Try again in a moment.";
          setActionStatus("error", "Ride entry was not updated", message);
          setCardBusy(card, false);
        }
      });

      card.replaceChildren(form);
      heading.tabIndex = -1;
      heading.focus();
    };

    const renderRideEntry = (entry: {
      id?: string;
      rideDate?: string | null;
      addressLabel?: string | null;
      latitude?: number | null;
      longitude?: number | null;
      distanceMiles?: number | null;
      effort?: string | null;
      rideNotes?: string | null;
      weatherNotes?: string | null;
      weatherSummary?: string | null;
      weatherTemperature?: string | null;
      windSpeed?: string | null;
      precipitationSummary?: string | null;
      durationMinutes?: number | null;
    }) => {
      const item = document.createElement("li");
      const card = document.createElement("article");

      item.className = "usa-card tablet:grid-col-12";
      card.className = "usa-card__container app-ride-card";

      const renderView = () => {
        const header = document.createElement("div");
        const date = document.createElement("p");
        const address = document.createElement("h3");
        const metaList = document.createElement("dl");
        const notes = document.createElement("p");
        const weather = document.createElement("p");
        const actions = document.createElement("div");
        const editButton = document.createElement("button");
        const deleteButton = document.createElement("button");

        header.className = "usa-card__header";
        date.className = "app-ride-date";
        address.className = "usa-card__heading";
        metaList.className = "app-ride-meta";
        notes.className = "app-ride-notes";
        weather.className = "app-ride-weather";
        actions.className = "app-ride-actions";
        editButton.className = "usa-button usa-button--outline";
        editButton.type = "button";
        editButton.textContent = "Edit";
        deleteButton.className = "usa-button usa-button--secondary";
        deleteButton.type = "button";
        deleteButton.textContent = "Delete";

        date.textContent = formatDate(entry.rideDate);
        address.textContent = entry.addressLabel || "Address unavailable";
        metaList.append(
          createMetaItem("Distance", formatDistance(entry.distanceMiles)),
          createMetaItem("Effort", formatEffort(entry.effort)),
        );
        notes.textContent = formatNotesPreview(entry.rideNotes, entry.weatherNotes);
        weather.textContent = formatWeatherSnapshot(entry);

        editButton.addEventListener("click", () => {
          clearActionStatus();
          renderEditForm(card, entry, renderView);
        });
        deleteButton.addEventListener("click", () => {
          void deleteRideEntry(entry);
        });

        header.append(date, address);
        actions.append(editButton, deleteButton);
        card.replaceChildren(header, metaList, notes, weather, actions);
      };

      renderView();
      item.append(card);

      return item;
    };

    const loadRideEntries = async (showLoading = true) => {
      if (!ridesList) {
        return;
      }

      setHidden(loadingState, !showLoading);
      setHidden(errorState, true);
      setHidden(emptyState, true);
      ridesList.replaceChildren();

      try {
        const entries = [];
        let nextToken = null;

        do {
          const response = await amplifyClient.models.RideEntry.list({
            limit: 100,
            nextToken,
          });

          if (response.errors?.length) {
            throw new Error("Saved rides could not load.");
          }

          entries.push(...response.data);
          nextToken = response.nextToken;
        } while (nextToken);

        entries.sort((first, second) =>
          String(second.rideDate || "").localeCompare(String(first.rideDate || "")),
        );

        setHidden(loadingState, true);
        setHidden(emptyState, entries.length > 0);
        ridesList.replaceChildren(...entries.map(renderRideEntry));
      } catch {
        setHidden(loadingState, true);
        setHidden(errorState, false);
      }
    };

    loadRideEntries();
  </script>
</UswdsLayout>
