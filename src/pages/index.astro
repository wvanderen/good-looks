---
import UswdsLayout from "../layouts/UswdsLayout.astro";
---

<UswdsLayout
  title="Good Looks | National Administration of Good Looks"
  description="Good Looks is an accessible, government-styled bike ride journal built with Astro, USWDS, and AWS Amplify."
>
  <section class="usa-section app-intro">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-7">
          <p class="usa-intro">National Administration of Good Looks</p>
          <h1>Good Looks</h1>
          <p>
            A government-styled ride journal for capturing bike rides, pairing
            each entry with public weather data, and saving the record for later.
          </p>
          <a class="usa-button" href="/journal/">Start a journal entry</a>
          <a class="usa-button usa-button--outline" href="/rides/">Manage saved rides</a>
        </div>
        <div class="tablet:grid-col-5 app-summary" aria-labelledby="status-heading">
          <h2 id="status-heading">MVP status</h2>
          <ul class="usa-list">
            <li>Accessible USWDS journal flow is implemented.</li>
            <li>Address lookup and NWS forecast enrichment are wired through Amplify.</li>
            <li>Saved ride entries persist to the Amplify data model.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="usa-section usa-section--light">
    <div class="grid-container">
      <div class="app-form-preview">
        <h2>Use the working journal flow</h2>
        <p>
          Address lookup, weather enrichment, review, save, edit, and delete all
          live in the journal and saved-rides pages so demo data can be managed
          in one place.
        </p>
        <a class="usa-button" href="/journal/">Open journal</a>
      </div>
    </div>
  </section>
</UswdsLayout>
